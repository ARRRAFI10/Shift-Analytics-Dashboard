# Copy to .env and adjust as needed. All values have sane defaults in settings.py.

DEBUG=True
SECRET_KEY=dev-insecure-change-me
ALLOWED_HOSTS=localhost,127.0.0.1

# Absolute or relative path to the source spreadsheet.
DATA_FILE_PATH=data/shift_data.xlsx

# Timezone used for parsing and display. The data is UTC; keep it UTC unless you
# have a deliberate reason to present another zone.
DISPLAY_TIMEZONE=UTC

# --- Cleaning tolerances / limits ---
# Allowed gap (hours) between stated HOURS and computed duration before a record
# is flagged as CORRECTED.
HOURS_TOLERANCE=0.1
# Spans longer than this (hours) are implausible and get quarantined.
MAX_SHIFT_HOURS=16

# --- Analytics ---
# Category whose consecutive-day runs form "streaks".
STREAK_TARGET_CATEGORY=Breakdown
# Only surface streaks at least this many days long.
MIN_STREAK_DAYS=2
# Reasons treated as non-productive on first seed. Comma separated.
NON_PRODUCTIVE_CATEGORIES=Breakdown,Unknown Failure
# How many imported dataset versions to keep before the oldest are pruned.
MAX_RETAINED_DATASETS=10

# Frontend dev origin(s) allowed via CORS. Comma separated.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
