# Local virtualenv and Python caches — rebuilt inside the image.
venv/
**/__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# Start from a clean database; the entrypoint migrates and reseeds.
db.sqlite3

# Never bake local secrets into the image.
.env

# Editor / OS noise.
.vscode/
.idea/
.DS_Store
Thumbs.db
